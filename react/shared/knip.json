{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "src/services/index.ts",
    "src/services/Service.ts",
    "src/components/index.ts",
    "src/hooks/index.ts",
    "src/stores/index.ts",
    "src/utils/index.ts",
    "src/i18n/index.ts",
    "src/theme/index.ts",
    "src/types/index.ts",
    "src/components/properties/index.ts",
    "src/components/properties/DatePicker.tsx",
    "src/components/CodeEditor/index.ts",
    "src/**/__tests__/**/*.test.{ts,tsx}",
    "src/**/__tests__/**/*.{ts,tsx}",
    "vitest.setup.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "exclude": ["duplicates"],
  "ignoreDependencies": [
    "dmn-js-decision-table",
    "@vitejs/plugin-react",
    "eslint-plugin-import-x",
    "eslint-plugin-react-hooks",
    "eslint-plugin-react-refresh",
    "globals",
    "typescript-eslint",
    "@vitest/coverage-v8"
  ],
  "vitest": false
}
