{
  "name": "bpm-merge-split",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "lint:fix": "eslint --config ../eslint.config.mjs --fix src/",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results/junit.xml --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "format": "prettier --write './src'",
    "knip": "knip",
    "depcruise": "depcruise --config ../.dependency-cruiser.cjs --output-type err src/"
  },
  "dependencies": {
    "@axelor/ui": "^0.6.3",
    "@studio/shared": "link:../shared",
    "bpmn-js": "^18.2.0",
    "immer": "^10.0.4",
    "lodash": "^4.17.21",
    "nanoid": "^5.0.6",
    "react-dropzone": "^14.2.3",
    "react-split-pane": "^0.1.92",
    "vite-plugin-svgr": "^4.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "knip": "^6.1.0",
    "prettier": "^3.8.1",
    "sass": "^1.72.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.4.21",
    "vite-plugin-checker": "0.12.0",
    "vitest": "^3.2.4"
  }
}
