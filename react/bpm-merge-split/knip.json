{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "src/**/__tests__/**/*.test.{ts,tsx}",
    "src/**/__tests__/**/*.{ts,tsx}",
    "src/**/__mocks__/**/*.{ts,tsx}",
    "vitest.setup.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "@vitejs/plugin-react",
    "vite-plugin-svgr",
    "vite-plugin-checker",
    "eslint-plugin-import-x",
    "eslint-plugin-react-hooks",
    "eslint-plugin-react-refresh",
    "globals",
    "typescript-eslint",
    "@vitest/coverage-v8"
  ],
  "vite": false,
  "vitest": false
}
