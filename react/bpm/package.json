{
  "name": "bpmnjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/App.tsx",
  "dependencies": {
    "@axelor/ui": "^0.6.3",
    "@bpmn-io/properties-panel": "^3.25.0",
    "@monaco-editor/react": "^4.6.0",
    "@studio/shared": "link:../shared",
    "@vitejs/plugin-react": "^4.3.0",
    "bpmn-js": "^18.2.0",
    "bpmn-js-bpmnlint": "^0.23.0",
    "bpmn-js-properties-panel": "^5.26.0",
    "bpmn-js-token-simulation": "^0.33.2",
    "bpmn-moddle": "^10.0.0",
    "bpmnlint": "^11.12.0",
    "bpmnlint-plugin-axelor": "file:./bpmnlint-plugin-axelor",
    "bpmnlint-utils": "^1.1.1",
    "camunda-bpmn-moddle": "^7.0.1",
    "classnames": "^2.2.6",
    "dayjs": "^1.11.10",
    "diagram-js": "^15.2.4",
    "diagram-js-minimap": "^5.1.0",
    "generic-builder": "link:../generic-builder",
    "ids": "1.0.0",
    "immer": "^10.0.4",
    "js-string-escape": "^1.0.1",
    "lodash": "^4.17.15",
    "mapper": "link:../mapper",
    "min-dash": "^3.5.2",
    "min-dom": "^4.1.0",
    "monaco-editor": "0.52.2",
    "nanoid": "^5.1.7",
    "re-resizable": "^6.5.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "timer-builder": "link:../timer-builder",
    "tiny-svg": "^2.2.2",
    "vite": "^5.4.21",
    "vite-plugin-svgr": "^4.5.0",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "install:generic-builder": "cd ../generic-builder && pnpm install",
    "install:mapper": "cd ../mapper && pnpm install",
    "install:timer-builder": "cd ../timer-builder && pnpm install",
    "preinstall": "npx only-allow pnpm && pnpm run install:generic-builder && pnpm run install:mapper && pnpm run install:timer-builder",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write './src'",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "lint:fix": "eslint --config ../eslint.config.mjs --fix src/",
    "lint:pack": "bpmnlint-pack-config -c .bpmnlintrc -o bundled-config.js -t es",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results/junit.xml --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "depcruise": "depcruise --config ../.dependency-cruiser.cjs --output-type err src/"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "./",
  "devDependencies": {
    "@msw/playwright": "^0.6.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/bpmn-moddle": "10.0.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "bpmnlint-pack-config": "0.9.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "knip": "^6.1.0",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "sass": "^1.71.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite-plugin-checker": "0.12.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "only-allow": "^1.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "@babel/runtime@<7.26.10": ">=7.26.10",
      "@babel/helpers@<7.26.10": ">=7.26.10",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "rollup@>=3.0.0 <3.30.0": ">=3.30.0",
      "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
      "undici@>=7.0.0 <7.24.0": "7.24.7",
      "undici@>=7.17.0 <7.24.0": "7.24.7",
      "brace-expansion@>=1.0.0 <1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0"
    }
  }
}
