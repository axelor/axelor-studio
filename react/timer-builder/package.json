{
  "name": "timer-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "dependencies": {
    "@axelor/ui": "^0.6.3",
    "@sbzen/re-cron": "^2.0.5",
    "@studio/shared": "link:../shared",
    "@vitejs/plugin-react": "^4.3.0",
    "bootstrap": "^5.3.8",
    "cron-validate": "^1.4.5",
    "dayjs": "^1.11.20",
    "iso8601-duration": "^2.1.1",
    "vite": "^5.4.21",
    "vite-plugin-svgr": "^4.5.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "lint:fix": "eslint --config ../eslint.config.mjs --fix src/",
    "format": "prettier --write './src'",
    "test": "vitest run --reporter=verbose",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results/junit.xml --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "depcruise": "depcruise --config ../.dependency-cruiser.cjs --output-type err src/"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "knip": "^6.1.0",
    "prettier": "^3.8.1",
    "sass": "^1.71.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite-plugin-checker": "0.12.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
