    <bpmn2:sequenceFlow id="Flow_1vrlupn" sourceRef="Activity_01i20vm" targetRef="Gateway_143irmq" />
    <bpmn2:scriptTask id="Activity_01i20vm" name="Get start date" scriptFormat="axelor" camunda:scriptValue="{&#34;fields&#34;:[{&#34;name&#34;:&#34;taskDate&#34;,&#34;type&#34;:&#34;DATE&#34;,&#34;condition&#34;:null,&#34;conditionMeta&#34;:null,&#34;value&#34;:{&#34;from&#34;:&#34;context&#34;,&#34;selected&#34;:{&#34;value&#34;:&#34;__date__&#34;},&#34;query&#34;:null,&#34;subFields&#34;:[{&#34;trackKey&#34;:0,&#34;title&#34;:&#34;Built In Variables&#34;,&#34;name&#34;:&#34;Built In Variables&#34;,&#34;type&#34;:&#34;built-in&#34;},{&#34;trackKey&#34;:1,&#34;name&#34;:&#34;__date__&#34;}]}}],&#34;targetModel&#34;:&#34;TeamTask&#34;,&#34;sourceModel&#34;:&#34;&#34;,&#34;sourceModelList&#34;:[],&#34;newRecord&#34;:false,&#34;savedRecord&#34;:true,&#34;save&#34;:true,&#34;isJson&#34;:false,&#34;createVariable&#34;:false,&#34;modelFrom&#34;:{&#34;title&#34;:&#34;Context&#34;,&#34;id&#34;:&#34;context&#34;}}">
      <bpmn2:incoming>Flow_0igqorh</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1vrlupn</bpmn2:outgoing>
      <bpmn2:script>def rec = __ctx__.find('TeamTask',teamTaskId)
rec.taskDate = __date__
return __ctx__.save(rec)</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:exclusiveGateway id="Gateway_143irmq" name="Evaluate priority" default="Flow_04u3zam">
