    <bpmn2:userTask id="Activity_1jhxofx" name="Assigne task" camunda:completedIf=" &#10;&#10;teamTask?.assignedTo?.fullName!=null " camunda:completedIfValue="[{&#34;metaModalName&#34;:&#34;TeamTask&#34;,&#34;metaModalType&#34;:&#34;metaModel&#34;,&#34;rules&#34;:[{&#34;id&#34;:1,&#34;parentId&#34;:-1,&#34;combinator&#34;:&#34;and&#34;,&#34;rules&#34;:[{&#34;isField&#34;:null,&#34;fieldName&#34;:&#34;assignedTo&#34;,&#34;operator&#34;:&#34;isNotNull&#34;,&#34;fieldValue&#34;:null,&#34;fieldValue2&#34;:null,&#34;isRelationalValue&#34;:null,&#34;relatedValueFieldName&#34;:null,&#34;relatedValueModal&#34;:null,&#34;fieldType&#34;:&#34;MANY_TO_ONE&#34;,&#34;field&#34;:{&#34;targetName&#34;:&#34;fullName&#34;,&#34;targetSearch&#34;:[&#34;fullName&#34;,&#34;name&#34;,&#34;code&#34;],&#34;name&#34;:&#34;assignedTo&#34;,&#34;perms&#34;:null,&#34;type&#34;:&#34;MANY_TO_ONE&#34;,&#34;title&#34;:&#34;Assigned to&#34;,&#34;target&#34;:&#34;com.axelor.auth.db.User&#34;},&#34;isShow&#34;:false,&#34;allField&#34;:[{&#34;targetName&#34;:&#34;fullName&#34;,&#34;targetSearch&#34;:[&#34;fullName&#34;,&#34;name&#34;,&#34;code&#34;],&#34;name&#34;:&#34;assignedTo&#34;,&#34;perms&#34;:null,&#34;type&#34;:&#34;MANY_TO_ONE&#34;,&#34;title&#34;:&#34;Assigned to&#34;,&#34;target&#34;:&#34;com.axelor.auth.db.User&#34;}]}]}]}]" camunda:completedIfCombinator="and">
