    <bpmn2:scriptTask id="Activity_09r8mcd" name="Set priority to urgent" scriptFormat="axelor" camunda:scriptValue="{&#34;fields&#34;:[{&#34;name&#34;:&#34;priority&#34;,&#34;type&#34;:&#34;STRING&#34;,&#34;condition&#34;:null,&#34;conditionMeta&#34;:null,&#34;value&#34;:{&#34;from&#34;:&#34;none&#34;,&#34;selected&#34;:{&#34;value&#34;:&#34;urgent&#34;},&#34;query&#34;:null,&#34;subFields&#34;:[]}}],&#34;targetModel&#34;:&#34;TeamTask&#34;,&#34;sourceModel&#34;:&#34;&#34;,&#34;sourceModelList&#34;:[],&#34;newRecord&#34;:false,&#34;savedRecord&#34;:false,&#34;save&#34;:true,&#34;isJson&#34;:false,&#34;createVariable&#34;:false,&#34;modelFrom&#34;:{&#34;title&#34;:&#34;Context&#34;,&#34;id&#34;:&#34;context&#34;}}">
      <bpmn2:incoming>Flow_0m2dgm6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_1r4tayh</bpmn2:outgoing>
      <bpmn2:script>teamTask.priority = 'urgent'
