      <bpmndi:BPMNShape id="Task_PS_Production_di" bpmnElement="Task_PS_Production" bioc:stroke="#3fbdd6" bioc:fill="#c5ebf3" color:background-color="#c5ebf3" color:border-color="#3fbdd6">
        <dc:Bounds x="1330" y="620" width="100" height="80" />
