      <bpmndi:BPMNShape id="Script_ForceEchantillon_di" bpmnElement="Script_ForceEchantillon" bioc:stroke="#e53935" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#e53935">
        <dc:Bounds x="450" y="55" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Script_CheckPreserie_di" bpmnElement="Script_CheckPreserie" bioc:stroke="#ff9e0f" bioc:fill="#ffeed4" color:background-color="#ffeed4" color:border-color="#ff9e0f">
        <dc:Bounds x="600" y="155" width="100" height="80" />
      </bpmndi:BPMNShape>

