        <dc:Bounds x="925" y="170" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="905" y="146" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_TypeDispatch_di" bpmnElement="GW_TypeDispatch" isMarkerVisible="true" bioc:stroke="#f9c000" bioc:fill="#fdecb3" color:background-color="#fdecb3" color:border-color="#f9c000">
        <dc:Bounds x="1045" y="170" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1029" y="146" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ====== SHAPES - EI Lane ====== -->
      <bpmndi:BPMNShape id="Task_EI_Planifie_di" bpmnElement="Task_EI_Planifie" bioc:stroke="#3fbdd6" bioc:fill="#c5ebf3" color:background-color="#c5ebf3" color:border-color="#3fbdd6">
        <dc:Bounds x="1170" y="420" width="100" height="80" />
