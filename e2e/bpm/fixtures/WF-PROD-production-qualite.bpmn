        <dc:Bounds x="150" y="360" width="2170" height="200" />
      </bpmndi:BPMNShape>

      <!-- Lane Preserie -->
      <bpmndi:BPMNShape id="Lane_Workflow_Preserie_di" bpmnElement="Lane_Workflow_Preserie" isHorizontal="true" bioc:stroke="#ff9e0f" color:border-color="#ff9e0f">
        <dc:Bounds x="150" y="560" width="2170" height="200" />
      </bpmndi:BPMNShape>

      <!-- Lane Serie -->
      <bpmndi:BPMNShape id="Lane_Workflow_Serie_di" bpmnElement="Lane_Workflow_Serie" isHorizontal="true" bioc:stroke="#55c041" color:border-color="#55c041">
        <dc:Bounds x="150" y="760" width="2170" height="170" />
      </bpmndi:BPMNShape>

      <!-- Lane Finalisation -->
      <bpmndi:BPMNShape id="Lane_Finalisation_di" bpmnElement="Lane_Finalisation" isHorizontal="true" bioc:stroke="#1e88e5" color:border-color="#1e88e5">
        <dc:Bounds x="150" y="930" width="2170" height="200" />
      </bpmndi:BPMNShape>

      <!-- ====== SHAPES - Qualification Lane ====== -->
      <bpmndi:BPMNShape id="Start_PROD01_di" bpmnElement="Start_PROD01" bioc:stroke="#55c041" bioc:fill="#ccecc6" color:background-color="#ccecc6" color:border-color="#55c041">
        <dc:Bounds x="212" y="177" width="36" height="36" />
