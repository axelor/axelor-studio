          <dc:Bounds x="196" y="220" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Script_CheckFinishedMO_di" bpmnElement="Script_CheckFinishedMO" bioc:stroke="#ff9e0f" bioc:fill="#ffeed4" color:background-color="#ffeed4" color:border-color="#ff9e0f">
        <dc:Bounds x="310" y="155" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_FinishedMOExists_di" bpmnElement="GW_FinishedMOExists" isMarkerVisible="true" bioc:stroke="#f9c000" bioc:fill="#fdecb3" color:background-color="#fdecb3" color:border-color="#f9c000">
        <dc:Bounds x="475" y="170" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="455" y="146" width="90" height="14" />
        </bpmndi:BPMNLabel>
