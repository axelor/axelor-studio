        <dc:Bounds x="1490" y="620" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ====== SHAPES - Serie Lane ====== -->
      <bpmndi:BPMNShape id="Task_SE_Planifie_di" bpmnElement="Task_SE_Planifie" bioc:stroke="#3fbdd6" bioc:fill="#c5ebf3" color:background-color="#c5ebf3" color:border-color="#3fbdd6">
        <dc:Bounds x="1170" y="810" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_SE_Production_di" bpmnElement="Task_SE_Production" bioc:stroke="#3fbdd6" bioc:fill="#c5ebf3" color:background-color="#c5ebf3" color:border-color="#3fbdd6">
        <dc:Bounds x="1330" y="810" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- ====== SHAPES - Finalisation Lane ====== -->
      <bpmndi:BPMNShape id="GW_MergeEnd_di" bpmnElement="GW_MergeEnd" isMarkerVisible="true" bioc:stroke="#f9c000" bioc:fill="#fdecb3" color:background-color="#fdecb3" color:border-color="#f9c000">
        <dc:Bounds x="1745" y="1005" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1725" y="1062" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Script_UpdateQualification_di" bpmnElement="Script_UpdateQualification" bioc:stroke="#1e88e5" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#1e88e5">
        <dc:Bounds x="1870" y="990" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Script_SetTermine_di" bpmnElement="Script_SetTermine" bioc:stroke="#55c041" bioc:fill="#ccecc6" color:background-color="#ccecc6" color:border-color="#55c041">
        <dc:Bounds x="2030" y="990" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="End_PROD01_di" bpmnElement="End_PROD01" bioc:stroke="#ff7043" bioc:fill="#ffd4c7" color:background-color="#ffd4c7" color:border-color="#ff7043">
        <dc:Bounds x="2192" y="1012" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2165" y="1055" width="90" height="40" />
        </bpmndi:BPMNLabel>
